---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Cas type - Réconciliation Meta, GA4 et back-office',
  description:
    'Cas type de réconciliation entre Meta Ads, GA4 et revenu back-office pour clarifier les décisions marketing.',
};

const deliverables = [
  'Table de réconciliation',
  'Règles de source de vérité',
  'Lecture des écarts normaux',
  'Liste des anomalies',
  'Recommandation de pilotage',
];
---

<Layout metadata={metadata}>
  <section class="not-prose mx-auto max-w-5xl px-4 py-14 sm:px-6 md:py-20">
    <p class="mb-4 text-sm font-bold uppercase tracking-wide text-primary">Cas type</p>
    <h1 class="font-heading text-4xl font-bold tracking-tight text-gray-900 dark:text-white md:text-5xl">
      Réconciliation Meta, GA4 et revenu back-office
    </h1>
    <p class="mt-6 max-w-3xl text-xl leading-relaxed text-muted dark:text-slate-400">
      Meta annonce un ROAS positif, GA4 affiche une autre réalité et le back-office raconte encore une troisième
      histoire. Le sujet n’est pas de forcer les chiffres à devenir identiques, mais de savoir quoi utiliser pour
      décider.
    </p>

    <div class="mt-12 grid gap-8 md:grid-cols-3">
      <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white">Meta Ads</h2>
        <p class="mt-3 text-muted dark:text-slate-400">Lecture média, attribution plateforme, optimisation campagne.</p>
      </article>
      <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white">GA4</h2>
        <p class="mt-3 text-muted dark:text-slate-400">Parcours observé, sources, événements et limites de collecte.</p>
      </article>
      <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white">Back-office</h2>
        <p class="mt-3 text-muted dark:text-slate-400">Revenu réel, commandes, remboursements, marge et finance.</p>
      </article>
    </div>

    <section class="mt-10 rounded-lg border border-primary/20 bg-primary/5 p-6">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Livrables</h2>
      <div class="mt-5 grid gap-3 sm:grid-cols-2">
        {deliverables.map((item) => <p class="text-sm font-medium text-muted dark:text-slate-300">{item}</p>)}
      </div>
    </section>
  </section>

  <CallToAction
    actions={[{ variant: 'primary', text: 'Analyser les écarts', href: '/prendre-un-rdv', icon: 'tabler:calendar' }]}
  >
    <Fragment slot="title">Vos chiffres média et revenu ne s’alignent pas ?</Fragment>
    <Fragment slot="subtitle">Nous pouvons cadrer une première table de réconciliation.</Fragment>
  </CallToAction>
</Layout>
