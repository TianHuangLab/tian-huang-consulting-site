---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Cas type - Validation Consent Mode',
  description: 'Cas type de validation technique Consent Mode, CMP, GTM et tags marketing.',
};

const scenarios = ['Acceptation complète', 'Refus complet', 'Absence de choix', 'Changement de préférence'];
---

<Layout metadata={metadata}>
  <section class="not-prose mx-auto max-w-5xl px-4 py-14 sm:px-6 md:py-20">
    <p class="mb-4 text-sm font-bold uppercase tracking-wide text-primary">Cas type</p>
    <h1 class="font-heading text-4xl font-bold tracking-tight text-gray-900 dark:text-white md:text-5xl">
      Validation Consent Mode
    </h1>
    <p class="mt-6 max-w-3xl text-xl leading-relaxed text-muted dark:text-slate-400">
      Après une modification CMP ou GTM, les conversions deviennent instables. Le but est de vérifier l’ordre de
      chargement, les consent states et le comportement réel des tags.
    </p>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {
        scenarios.map((scenario) => (
          <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900">
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">{scenario}</h2>
            <p class="mt-3 text-muted dark:text-slate-400">
              Vérification GTM Preview, Tag Assistant, Network et état du consentement.
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <CallToAction
    actions={[
      { variant: 'primary', text: 'Valider le consentement', href: '/prendre-un-rdv', icon: 'tabler:calendar' },
    ]}
  >
    <Fragment slot="title">Votre tracking change selon le consentement ?</Fragment>
    <Fragment slot="subtitle">Un test technique permet de documenter ce qui se déclenche réellement.</Fragment>
  </CallToAction>
</Layout>
